# =============================================================================
# Contoso HR Agent — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure AI Foundry / AIServices (REQUIRED)
#
# To find your values after deployment:
#   Endpoint: Azure Portal → AI Foundry → your-account → Keys and Endpoint
#   Key     : Same blade → Key 1
#   OR via CLI:
#     az cognitiveservices account show --name <your-account> -g <your-rg> --query properties.endpoint -o tsv
#     az cognitiveservices account keys list --name <your-account> -g <your-rg> --query key1 -o tsv
# -----------------------------------------------------------------------------
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-account>.cognitiveservices.azure.com/
AZURE_AI_FOUNDRY_KEY=your-api-key-here
AZURE_AI_FOUNDRY_CHAT_MODEL=gpt-4-1-mini
AZURE_AI_FOUNDRY_EMBEDDING_MODEL=text-embedding-3-large
AZURE_AI_FOUNDRY_API_VERSION=2024-05-01-preview

# -----------------------------------------------------------------------------
# Azure Subscription / Tenant (for reference and Azure MCP server)
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=contoso-hr-rg

# -----------------------------------------------------------------------------
# Brave Search API (optional — enables web research in ResumeAnalyst agent)
# Free tier at https://api.search.brave.com/register (2,000 queries/month free)
# If not set, the agent skips web search and falls back to resume-only analysis.
# -----------------------------------------------------------------------------
BRAVE_API_KEY=your-brave-search-api-key-here

# -----------------------------------------------------------------------------
# Runtime Settings (defaults shown — safe to leave as-is)
# -----------------------------------------------------------------------------
LLM_TEMPERATURE=0.2
WATCH_POLL_SECONDS=3
LOG_LEVEL=INFO
ENGINE_PORT=8080
MCP_PORT=8081
